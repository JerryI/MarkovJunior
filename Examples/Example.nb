Notebook[{Cell["River generator", "Title"], Cell["This is a basic \
MarkovJunior example that procedurally generates rivers.\n\nLoad the library \
first:", "Text"], Cell["PacletDirectoryLoad[ParentDirectory[NotebookDirectory\
[]]]; \nNeeds[\"CoffeeLiqueur`Workshop`MarkovJunior`\" -> \"mj`\"]; ", 
   "Input"], Cell["Create a set of rules following this pattern:\n\n```\n{\n  \
All | 1,  (* apply the rule to all found matches or to 1 randomly chosen \
match *)\n  _Integer | Infinity, (* maximum number of steps for this rule set \
*)\n                       (* allowed symmetry operations *)\n  Automatic | \
All | None | \"Mirror\" | ...,\n  {\n    a -> b,  (* rule 1 *)\n    c -> d   \
(* rule 2 *)\n    ...\n  }\n}\n```", "Text"], 
  Cell[
   "Here is a set of rules that generates a river, then adds some grass:", 
   "Text"], Cell["rules = {}; \nAppendTo[rules, {1, 1, Automatic, \
{GrayLevel[0] -> RGBColor[1, 1, 0]}}]; \nAppendTo[rules, {1, 1, Automatic, \
{GrayLevel[0] -> RGBColor[1, 0, 0]}}]; \nAppendTo[rules, {1, Infinity, \
Automatic, {{a___, RGBColor[1, 0, 0], GrayLevel[0], b___} :> {a, RGBColor[1, \
0, 0], RGBColor[1, 0, 0], b}, {a___, RGBColor[1, 1, 0], GrayLevel[0], b___} \
:> {a, RGBColor[1, 1, 0], RGBColor[1, 1, 0], b}}}]; \nAppendTo[rules, {All, \
Infinity, Automatic, {{a___, RGBColor[1, 0, 0], RGBColor[1, 1, 0], b___} :> \
{a, RGBColor[1/3, 1/3, 1], RGBColor[1/3, 1/3, 1], b}}}]; \nAppendTo[rules, \
{All, Infinity, Automatic, {{a___, RGBColor[1, 1, 0], b___} :> {a, \
GrayLevel[0], b}, {a___, RGBColor[1, 0, 0], b___} :> {a, GrayLevel[0], b}}}]; \
\nAppendTo[rules, {All, 1, Automatic, {{a___, RGBColor[1/3, 1/3, 1], \
GrayLevel[0], b___} :> {a, RGBColor[1/3, 1/3, 1], RGBColor[1/3, 1/3, 1], \
b}}}]; \nAppendTo[rules, {All, Infinity, Automatic, {{a___, RGBColor[1/3, \
1/3, 1], GrayLevel[0], b___} :> {a, RGBColor[0, 1, 0], RGBColor[0, 1, 0], \
b}}}]; \nAppendTo[rules, {1, 13, Automatic, {{a___, GrayLevel[0], b___} :> \
{a, RGBColor[0, 2/3, 0], b}}}]; \nAppendTo[rules, {1, Infinity, Automatic, \
{{a___, RGBColor[0, 2/3, 0], GrayLevel[0], b___} :> {a, RGBColor[0, 2/3, 0], \
RGBColor[0, 2/3, 0], b}, {a___, RGBColor[0, 1, 0], GrayLevel[0], b___} :> {a, \
RGBColor[0, 1, 0], RGBColor[0, 1, 0], b}}}]; \nstate = \
mj`MarkovState[Table[GrayLevel[0], {20}, {20}], rules]", "Input"], 
  Cell["Now evaluate the state indefinitely and watch the result live:", 
   "Text"], Cell["DynamicModule[{state = initialState[40]}, \
Dynamic[Refresh[If[ !mj`FinishedQ[state], state = mj`Propagate[state]]; \
ArrayPlot[mj`GetArray[state], PixelConstrained -> 10], UpdateInterval -> \
1/30, TrackedSymbols :> {}]]]", "Input"], 
  Cell["To export the animation, use an `Image` wrapper:", "Text"], 
  Cell["Table[ImageResize[Image[mj`GetArray[state = mj`Propagate[state]; \
state = mj`Propagate[state]; state = mj`Propagate[state]]], {350, 350}, \
Method -> \"NearestNeighbor\"], {250}]; \nExport[\"ex.gif\", AnimatedImage[%, \
FrameRate -> 25]]", "Input"]}]
